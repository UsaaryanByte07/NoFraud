{
    "manifest_version": 3,
    "name": "NoFraudExtension",
    "description": "Cybersecurity Extension for detecting phishing, scams, malicious ads and protecting user privacy.",
    "version": "1.0",
    "permissions": [
        "tabs",
        "storage",
        "activeTab",
        "scripting",
        "webRequest",
        "webNavigation"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon/icon16.png",
            "48": "icon/icon48.png",
            "128": "icon/icon128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "threatDetector.js",
                "privacyGuard.js",
                "adBlocker.js",
                "contentScript.js"
            ],
            "run_at": "document_end"
        }
    ],
    "icons": {
        "16": "icon/icon16.png",
        "48": "icon/icon48.png",
        "128": "icon/icon128.png"
    }
}